# Copy to .env.production and fill in all values before running deploy.sh
# Generate BETTER_AUTH_SECRET with: openssl rand -base64 32

# --- Neon DB (external) ---
DATABASE_URL=postgresql://user:password@host.neon.tech/library_db?sslmode=require

# --- Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://library.beres.io

# --- MinIO credentials (same value used for MINIO_ROOT_USER and MINIO_ACCESS_KEY) ---
MINIO_ROOT_USER=library_minio
MINIO_ROOT_PASSWORD=change_this_to_a_strong_password

# --- MinIO runtime config (used by the app container) ---
# MINIO_ENDPOINT: internal Docker network hostname (container name)
MINIO_ENDPOINT=library_minio
# MINIO_PORT: internal MinIO port (no SSL inside Docker network)
MINIO_PORT=9000
MINIO_ACCESS_KEY=library_minio
MINIO_SECRET_KEY=change_this_to_a_strong_password
MINIO_BUCKET=library-covers
MINIO_USE_SSL=false

# --- MinIO public URL (used for cover image URLs stored in DB) ---
# MINIO_PUBLIC_HOST: public domain Nginx proxies to MinIO
MINIO_PUBLIC_HOST=minio.library.beres.io
# MINIO_PUBLIC_PORT: 443 because Nginx terminates TLS (port omitted from URLs for standard HTTPS)
MINIO_PUBLIC_PORT=443
