# ============================================================
# Library Management System — Environment Variables
# Copy this file to .env and fill in the values below.
# ============================================================

# --- Database ---
# For Docker Compose (VPS): uses the internal "postgres" service name
DATABASE_URL="postgresql://library_user:library_password@postgres:5432/library_db"
# For local dev (outside Docker), use: postgresql://library_user:library_password@localhost:5433/library_db

# --- Auth (better-auth) ---
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET="change-this-to-a-strong-random-secret"
# Your app's public URL — used for auth redirects and CSRF checks
# Example: http://123.45.67.89:3000  or  https://library.yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"

# --- MinIO public access ---
# MINIO_PUBLIC_HOST: the hostname browsers use to reach MinIO (your VPS IP or domain).
# This is baked into the Next.js image at build time (next/image remotePatterns)
# AND used at runtime to generate stored cover URLs.
# Do NOT include http:// — just the hostname or IP.
# Example: 123.45.67.89  or  storage.yourdomain.com
MINIO_PUBLIC_HOST="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
